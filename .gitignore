# The .vscode folder contains configuration for VS Code.
# It is generally acceptable to check in the settings file but not the cache.
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/

# Exceptions to above rules.
!/packages/*/pubspec.lock
